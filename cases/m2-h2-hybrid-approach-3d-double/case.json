{
  "id": "m2-h2-hybrid-approach-3d-double",
  "description": "3D Hybrid-PIC double-blob approach (pre-merge) gate.",
  "engine": "warpx",
  "gate_class": "hybrid_gate",
  "physical_validity": "3d_hybrid_approach",
  "inputs": [
    "inputs/warpx_args.json"
  ],
  "run": [
    {
      "name": "prepare-run-dir",
      "cmd": [
        "mkdir",
        "-p",
        "{output_raw}/run"
      ]
    },
    {
      "name": "run-warpx-3d-hybrid",
      "timeout_s": 1800,
      "cmd": [
        "env",
        "OMP_NUM_THREADS=1",
        "PYTHONPATH=pic-warpx-25.11/build-3d/lib/site-packages",
        "{python}",
        "warpx-driver/warpx_driver_3d.py",
        "--from-json",
        "{case_dir}/inputs/warpx_args.json",
        "--metadata-dir",
        "{output_raw}/run",
        "--diag-dir",
        "{output_raw}/run/diag",
        "--run-tag",
        "m2-h2-hybrid-approach-3d-double"
      ]
    }
  ],
  "analyze": [
    {
      "name": "analyze-h2-approach",
      "cmd": [
        "{python}",
        "tools/analyze_h2_approach_case.py",
        "--diag-dir",
        "{output_raw}/run/diag",
        "--metadata",
        "{output_raw}/run/warpx_run_m2-h2-hybrid-approach-3d-double.json",
        "--metrics",
        "{output_analysis}/metrics.json",
        "--plots-dir",
        "{output_plots}",
        "--csv",
        "{output_analysis}/separation_series.csv",
        "--rho-threshold-frac",
        "0.8",
        "--rho-bg-quantile",
        "5",
        "--sep-mode",
        "x"
      ]
    }
  ],
  "metrics_file": "{output_analysis}/metrics.json",
  "thresholds": [
    {
      "metric": "ran_to_completion",
      "op": "==",
      "value": true
    },
    {
      "metric": "num_outputs",
      "op": ">=",
      "value": 8
    },
    {
      "metric": "no_nan_in_metrics",
      "op": "==",
      "value": true
    },
    {
      "metric": "drop_breach",
      "op": "==",
      "value": false
    },
    {
      "metric": "sep_ratio",
      "op": "<=",
      "value": 0.7
    }
  ],
  "artifacts": [
    "{output_raw}/run/warpx_run_m2-h2-hybrid-approach-3d-double.json",
    "{output_analysis}/metrics.json",
    "{output_analysis}/separation_series.csv",
    "{output_plots}/separation_vs_time.png",
    "{output_plots}/centroid_paths_two_blobs.png",
    "{output_plots}/energy_budget_vs_time.png",
    "{output_plots}/density_snapshot.png"
  ]
}
