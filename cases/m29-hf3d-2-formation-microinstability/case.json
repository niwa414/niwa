{
  "id": "m29-hf3d-2-formation-microinstability",
  "description": "HF3D animation #2: formation-stage micro-instability and magnetic-flux-loss narrative in 3D.",
  "engine": "pipeline",
  "gate_class": "hf3d_animation_formation_microinstability",
  "physical_validity": "visual_high_fidelity_3d",
  "inputs": [
    "../../outputs/m9-h4-1-mhd-seeded-hybrid-3d-rotation/raw/run/diag/diag1000000/Header"
  ],
  "run": [
    {
      "name": "noop",
      "cmd": [
        "true"
      ]
    }
  ],
  "analyze": [
    {
      "name": "render-hf3d-formation",
      "cmd": [
        "{python}",
        "tools/render_hf3d_formation_microinstability.py",
        "--diag-dir",
        "outputs/m9-h4-1-mhd-seeded-hybrid-3d-rotation/raw/run/diag",
        "--formation-frac",
        "0.55",
        "--max-frames",
        "16",
        "--point-budget",
        "12000",
        "--fps",
        "10",
        "--mp4-out",
        "{output_plots}/formation_microinstability_3d.mp4",
        "--gif-out",
        "{output_plots}/formation_microinstability_3d.gif",
        "--metrics-out",
        "{output_analysis}/metrics.json",
        "--summary-out",
        "{output_analysis}/hf3d_formation.md"
      ]
    }
  ],
  "metrics_file": "{output_analysis}/metrics.json",
  "thresholds": [
    {
      "metric": "frames_rendered",
      "op": ">=",
      "value": 6
    },
    {
      "metric": "m1_amp_peak",
      "op": ">",
      "value": 0.0
    },
    {
      "metric": "flux_loss_frac_peak",
      "op": ">",
      "value": 0.0
    },
    {
      "metric": "render_success",
      "op": "==",
      "value": true
    }
  ],
  "artifacts": [
    "{output_analysis}/metrics.json",
    "{output_analysis}/hf3d_formation.md",
    "{output_plots}/formation_microinstability_3d.mp4",
    "{output_plots}/formation_microinstability_3d.gif"
  ]
}
