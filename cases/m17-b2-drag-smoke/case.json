{
  "id": "m17-b2-drag-smoke",
  "description": "P6.4 energy-drag smoke (path verification).",
  "case_notes": "Energy drag smoke: enable_energy_drag=True, energy_drag_nu_scale=1.0, max_steps=8.",
  "engine": "warpx",
  "gate_class": "b2_drag_smoke",
  "physical_validity": "b2_drag_smoke",
  "inputs": [
    "inputs/warpx_args.json",
    "inputs/h5_seed_config.json"
  ],
  "run": [
    {
      "name": "prepare-run-dir",
      "cmd": [
        "mkdir",
        "-p",
        "{output_raw}/run"
      ]
    },
    {
      "name": "run-warpx-3d-hybrid",
      "timeout_s": 43200,
      "cmd": [
        "env",
        "OMP_NUM_THREADS=4",
        "PYTHONPATH=pic-warpx-25.11/build-3d/lib/site-packages",
        "{python}",
        "warpx-driver/warpx_driver_3d.py",
        "--from-json",
        "{case_dir}/inputs/warpx_args.json",
        "--init-mode",
        "opmd_double_seed",
        "--opmd-fluid",
        "outputs/m9-h4-1-mhd-seeded-hybrid-3d-rotation/raw/run/fluid_init.h5",
        "--opmd-b",
        "outputs/m9-h4-1-mhd-seeded-hybrid-3d-rotation/raw/run/B_ext.h5",
        "--metadata-dir",
        "{output_raw}/run",
        "--diag-dir",
        "{output_raw}/run/diag",
        "--run-tag",
        "m17-b2-drag-smoke"
      ]
    }
  ],
  "analyze": [],
  "artifacts": [
    "{output_raw}/run/warpx_heartbeat.json",
    "{output_raw}/run/warpx_run_m17-b2-drag-smoke.json",
    "{output_analysis}/metrics_drag.json"
  ],
  "metrics_file": "{output_analysis}/metrics_drag.json",
  "artifact_policy": {
    "archive_pass": false,
    "prune_raw_on_fail": false,
    "prune_raw_on_pass": false
  },
  "thresholds": [
    {
      "metric": "drag_apply_calls",
      "op": ">",
      "value": 0
    },
    {
      "metric": "drag_particles_touched",
      "op": ">",
      "value": 0
    },
    {
      "metric": "drag_delta_u2_sum",
      "op": "!=",
      "value": 0.0
    }
  ]
}