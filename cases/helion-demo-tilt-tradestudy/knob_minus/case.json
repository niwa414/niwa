{
  "id": "helion-demo-tilt-tradestudy-knob-minus",
  "description": "Helion demo trade study knob_minus (single knob: shift=-0.002).",
  "engine": "warpx",
  "gate_class": "helion_demo_tilt_trade_study",
  "physical_validity": "single_knob_shift_trade_study",
  "case_notes": "Replay source diagnostics into demo KPI gate; source case m17-b2-p33-off352-drive100-repeat128-drift0330-shiftn0020.",
  "metadata": {
    "trade_study": {
      "knob_name": "shift",
      "knob_value": -0.002,
      "role": "knob_minus",
      "source_case_id": "m17-b2-p33-off352-drive100-repeat128-drift0330-shiftn0020"
    }
  },
  "artifact_policy": {
    "archive_pass": false,
    "prune_raw_on_pass": false,
    "prune_raw_on_fail": false
  },
  "run": [
    {
      "name": "prepare-run-dir",
      "cmd": [
        "mkdir",
        "-p",
        "{output_raw}/run/diag/reducedfiles",
        "{output_raw}/run/diags/reducedfiles",
        "{output_analysis}"
      ]
    },
    {
      "name": "sync-source-run",
      "cmd": [
        "cp",
        "-R",
        "outputs/m17-b2-p33-off352-drive100-repeat128-drift0330-shiftn0020/raw/run/.",
        "{output_raw}/run/"
      ]
    },
    {
      "name": "sync-source-metrics",
      "cmd": [
        "cp",
        "outputs/m17-b2-p33-off352-drive100-repeat128-drift0330-shiftn0020/analysis/metrics.json",
        "{output_analysis}/source_metrics.json"
      ]
    },
    {
      "name": "sync-source-formation",
      "cmd": [
        "cp",
        "outputs/m17-b2-p33-off352-drive100-repeat128-drift0330-shiftn0020/analysis/metrics_formation.json",
        "{output_analysis}/source_metrics_formation.json"
      ]
    }
  ],
  "analyze": [
    {
      "name": "analyze-helion-demo-case",
      "cmd": [
        "{python}",
        "tools/analyze_helion_demo_case.py",
        "--source-metrics",
        "{output_analysis}/source_metrics.json",
        "--source-formation",
        "{output_analysis}/source_metrics_formation.json",
        "--output-metrics",
        "{output_analysis}/metrics.json",
        "--source-case-id",
        "m17-b2-p33-off352-drive100-repeat128-drift0330-shiftn0020",
        "--knob-name",
        "shift",
        "--knob-value",
        "-0.002",
        "--label",
        "knob_minus",
        "--compression-threshold",
        "1.001",
        "--energy-threshold",
        "1e-6",
        "--tilt-threshold",
        "0.05"
      ]
    }
  ],
  "metrics_file": "{output_analysis}/metrics.json",
  "thresholds": [
    {
      "metric": "ran_to_completion",
      "op": "==",
      "value": true
    },
    {
      "metric": "no_nan_in_metrics",
      "op": "==",
      "value": true
    },
    {
      "metric": "merge_time_exists",
      "op": "==",
      "value": true
    },
    {
      "metric": "compression_ratio",
      "op": ">=",
      "value": 1.001
    },
    {
      "metric": "tilt_amp_max",
      "op": "<=",
      "value": 0.05
    },
    {
      "metric": "energy_accounting_ok",
      "op": "==",
      "value": true
    }
  ],
  "artifacts": [
    "{output_raw}/run/warpx_heartbeat.json",
    "{output_raw}/run/warpx_run_m17-b2-p33-off352-drive100-repeat128.json",
    "{output_raw}/run/diag/reducedfiles/COIL.txt",
    "{output_raw}/run/diags/reducedfiles/ENERGY0D.txt",
    "{output_raw}/run/diags/reducedfiles/PNUM.txt",
    "{output_raw}/run/diags/reducedfiles/PENERGY.txt",
    "{output_raw}/run/diags/reducedfiles/RHOMAX.txt",
    "{output_analysis}/source_metrics.json",
    "{output_analysis}/source_metrics_formation.json",
    "{output_analysis}/metrics.json"
  ]
}
