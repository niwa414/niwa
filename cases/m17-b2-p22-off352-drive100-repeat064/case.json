{
  "analyze": [
    {
      "cmd": [
        "{python}",
        "tools/analyze_formation_0d.py",
        "--particle-number",
        "{output_raw}/run/diags/reducedfiles/PNUM.txt",
        "--rho-max",
        "{output_raw}/run/diags/reducedfiles/RHOMAX.txt",
        "--particle-energy",
        "{output_raw}/run/diags/reducedfiles/PENERGY.txt",
        "--field-energy",
        "{output_raw}/run/diags/reducedfiles/ENERGY0D.txt",
        "--metrics-out",
        "{output_analysis}/metrics_formation.json"
      ],
      "name": "analyze-formation-0d"
    },
    {
      "cmd": [
        "{python}",
        "tools/analyze_u2_hist.py",
        "--hist",
        "{output_raw}/run/diag/reducedfiles/U2Hist.txt",
        "--warpx-args",
        "{case_dir}/inputs/warpx_args.json",
        "--metrics-out",
        "{output_analysis}/metrics_u2hist.json"
      ],
      "name": "analyze-u2-hist"
    },
    {
      "cmd": [
        "{python}",
        "tools/analyze_h5_merge_tilt_gamma.py",
        "--h3a-metrics",
        "{output_analysis}/metrics_h3a.json",
        "--h3b-metrics",
        "{output_analysis}/metrics_h3b.json",
        "--warpx-meta",
        "{output_raw}/run/warpx_run_m17-b2-p22-off352-drive100-repeat064.json",
        "--metrics-out",
        "{output_analysis}/metrics.json"
      ],
      "name": "analyze-h5-merge-gamma"
    },
    {
      "cmd": [
        "{python}",
        "tools/analyze_pulse_kpi.py",
        "--case",
        "m17-b2-p22-off352-drive100-repeat064"
      ],
      "name": "analyze-pulse-kpi"
    }
  ],
  "artifact_policy": {
    "archive_pass": false,
    "prune_raw_on_fail": false,
    "prune_raw_on_pass": false
  },
  "artifacts": [
    "{output_raw}/run/warpx_heartbeat.json",
    "{output_raw}/run/diag/reducedfiles/COIL.txt",
    "{output_raw}/run/diag/reducedfiles/U2Hist.txt",
    "{output_analysis}/metrics_u2hist.json",
    "{output_analysis}/metrics.json",
    "{output_analysis}/metrics_pulse_kpi.json",
    "{output_raw}/run/diags/reducedfiles/PNUM.txt",
    "{output_raw}/run/diags/reducedfiles/RHOMAX.txt",
    "{output_raw}/run/diags/reducedfiles/PENERGY.txt",
    "{output_raw}/run/diags/reducedfiles/ENERGY0D.txt",
    "{output_analysis}/metrics_formation.json"
  ],
  "case_notes": "driveAmp_scale=1.0; inject_repeat_nsteps=64; off_step=352; max_steps=513.",
  "description": "P22 DOE9 @ off_step=352 (driveAmp=1.0, repeat=64).",
  "engine": "warpx",
  "gate_class": "b2_p18_envelope",
  "id": "m17-b2-p22-off352-drive100-repeat064",
  "inputs": [
    "inputs/warpx_args.json",
    "inputs/h5_seed_config.json"
  ],
  "metrics_file": "{output_analysis}/metrics_formation.json",
  "physical_validity": "b2_p18_envelope",
  "run": [
    {
      "cmd": [
        "mkdir",
        "-p",
        "{output_raw}/run"
      ],
      "name": "prepare-run-dir"
    },
    {
      "cmd": [
        "env",
        "OMP_NUM_THREADS=4",
        "PYTHONPATH=pic-warpx-25.11/build-3d/lib/site-packages",
        "{python}",
        "warpx-driver/warpx_driver_3d.py",
        "--from-json",
        "{case_dir}/inputs/warpx_args.json",
        "--init-mode",
        "opmd_double_seed",
        "--opmd-fluid",
        "outputs/m9-h4-1-mhd-seeded-hybrid-3d-rotation/raw/run/fluid_init.h5",
        "--opmd-b",
        "outputs/m9-h4-1-mhd-seeded-hybrid-3d-rotation/raw/run/B_ext.h5",
        "--metadata-dir",
        "{output_raw}/run",
        "--diag-dir",
        "{output_raw}/run/diag",
        "--run-tag",
        "m17-b2-p22-off352-drive100-repeat064"
      ],
      "name": "run-warpx-3d-hybrid",
      "timeout_s": 43200
    }
  ],
  "thresholds": [
    {
      "metric": "formation_series_len",
      "op": ">=",
      "value": 129
    },
    {
      "metric": "formation_has_nan",
      "op": "==",
      "value": false
    }
  ]
}