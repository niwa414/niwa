{
  "id": "m15-a4-eb-movingwall-short",
  "description": "A4.2 embedded boundary + moving-wall short window using frc_merge with a tapered cyl_wall profile.",
  "engine": "athena",
  "gate_class": "a4_eb_gate",
  "physical_validity": "limited",
  "inputs": [
    "inputs/athinput.a4_eb_movingwall_short"
  ],
  "run": [
    {
      "name": "build-athena",
      "timeout_s": 600,
      "cmd": [
        "{python}",
        "tools/build_athena.py",
        "--athena-root",
        "athena-24.0",
        "--prob",
        "frc_merge",
        "--jobs",
        "4",
        "--magnetic",
        "--clean"
      ]
    },
    {
      "name": "prepare-run-dir",
      "cmd": [
        "mkdir",
        "-p",
        "{output_raw}/run"
      ]
    },
    {
      "name": "run-athena",
      "timeout_s": 900,
      "cmd": [
        "athena-24.0/bin/athena",
        "-i",
        "{case_dir}/inputs/athinput.a4_eb_movingwall_short",
        "-d",
        "{output_raw}/run"
      ]
    }
  ],
  "analyze": [
    {
      "name": "analyze-a4-eb-wall",
      "cmd": [
        "{python}",
        "tools/analyze_a4_eb_wall_case.py",
        "--run-dir",
        "{output_raw}/run",
        "--athinput",
        "{case_dir}/inputs/athinput.a4_eb_movingwall_short",
        "--metrics",
        "{output_analysis}/metrics.json",
        "--plots-dir",
        "{output_plots}"
      ]
    }
  ],
  "metrics_file": "{output_analysis}/metrics.json",
  "thresholds": [
    {
      "metric": "ran_to_completion",
      "op": "==",
      "value": true
    },
    {
      "metric": "blocked_flux_faces_count",
      "op": ">",
      "value": 0
    },
    {
      "metric": "piston_metric",
      "op": ">",
      "value": 0.0
    }
  ],
  "thresholds_layer1": [
    {
      "metric": "ran_to_completion",
      "op": "==",
      "value": true
    },
    {
      "metric": "blocked_flux_faces_count",
      "op": ">",
      "value": 0
    },
    {
      "metric": "piston_metric",
      "op": ">",
      "value": 0.0
    }
  ],
  "thresholds_layer2": [
    {
      "metric": "mass_budget_residual_geom_rel",
      "op": "<=",
      "value": 0.002
    },
    {
      "metric": "leak_mass_frac_max",
      "op": "<=",
      "value": 0.01
    },
    {
      "metric": "mass_rel_drift_in",
      "op": "<=",
      "value": 0.01
    }
  ],
  "known_gaps": [
    "moving_wall_eb_leak_geom_residual_nonzero"
  ],
  "known_gap_metrics": {
    "mass_budget_residual_geom_rel": 0.001696298530094286,
    "leak_thresh_geom": 0.002,
    "tlim": 1.4,
    "piston_waveform_scale": 0.3
  },
  "artifacts": [
    "{output_raw}/run/frc_merge.hst",
    "{output_analysis}/metrics.json",
    "{output_plots}/eb_mask_snapshot.png",
    "{output_plots}/leak_mass_out_vs_time.png",
    "{output_logs}/run_run-athena.log",
    "{output_logs}/run_build-athena.log"
  ]
}
