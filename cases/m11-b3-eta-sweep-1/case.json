{
  "id": "m11-b3-eta-sweep-1",
  "description": "B3 resistivity sweep (eta_scale=1.0).",
  "engine": "warpx",
  "gate_class": "b3_eta_sweep",
  "physical_validity": "eta_sweep",
  "case_status": "supplemental",
  "case_notes": "Hybrid resistivity scale sweep; eta_scale=1.0.",
  "inputs": [
    "inputs/warpx_args.json"
  ],
  "run": [
    {
      "name": "prepare-run-dir",
      "cmd": [
        "mkdir",
        "-p",
        "{output_raw}/run"
      ]
    },
    {
      "name": "run-warpx-3d-hybrid",
      "timeout_s": 1800,
      "cmd": [
        "env",
        "OMP_NUM_THREADS=1",
        "PYTHONPATH=pic-warpx-25.11/build-3d/lib/site-packages",
        "{python}",
        "warpx-driver/warpx_driver_3d.py",
        "--from-json",
        "{case_dir}/inputs/warpx_args.json",
        "--metadata-dir",
        "{output_raw}/run",
        "--diag-dir",
        "{output_raw}/run/diag",
        "--run-tag",
        "m11-b3-eta-sweep-1"
      ]
    }
  ],
  "analyze": [
    {
      "name": "analyze-hybrid-3d",
      "cmd": [
        "{python}",
        "tools/analyze_warpx_tilt_3d_case.py",
        "--diag-dir",
        "{output_raw}/run/diag",
        "--metadata",
        "{output_raw}/run/warpx_run_m11-b3-eta-sweep-1.json",
        "--metrics",
        "{output_analysis}/metrics.json",
        "--plots-dir",
        "{output_plots}",
        "--csv",
        "{output_analysis}/centroid_series.csv"
      ]
    }
  ],
  "metrics_file": "{output_analysis}/metrics.json",
  "thresholds": [
    {
      "metric": "ran_to_completion",
      "op": "==",
      "value": true
    },
    {
      "metric": "num_outputs",
      "op": ">=",
      "value": 6
    },
    {
      "metric": "no_nan_in_metrics",
      "op": "==",
      "value": true
    },
    {
      "metric": "drop_breach",
      "op": "==",
      "value": false
    }
  ],
  "artifacts": [
    "{output_raw}/run/warpx_run_m11-b3-eta-sweep-1.json",
    "{output_analysis}/metrics.json",
    "{output_analysis}/centroid_series.csv",
    "{output_plots}/tilt_centroid_amp_vs_time.png",
    "{output_plots}/tilt_centroid_xy_path.png",
    "{output_plots}/energy_budget_vs_time.png",
    "{output_plots}/density_snapshot.png"
  ]
}
