<comment>
  A2 formation + translation gate (Hall-MHD). Uses frc_merge with axial bulk drift
  to produce a formed structure that translates along x1 (axial).
</comment>

<job>
  problem_id   = frc_merge
  maxout       = 30
</job>

<mesh>
  ix1_bc = outflow
  ox1_bc = outflow
  ix2_bc = reflecting
  ox2_bc = reflecting
  ix3_bc = periodic
  ox3_bc = periodic

  x1min = -2.0
  x1max =  2.0
  x2min = -1.0
  x2max =  1.0
  x3min = 0.0
  x3max = 0.1

  nx1 = 128
  nx2 = 64
  nx3 = 1
</mesh>

<time>
  cfl_number = 0.15
  nlim       = -1
  tlim       = 6.0
</time>

<output1>
  file_type = vtk
  dt        = 0.25
  variable  = prim
</output1>

<output2>
  file_type = hst
  dt        = 0.1
</output2>

<problem>
  rho0                 = 1.0
  p0                   = 0.05
  rho_core             = 2.0
  p_core               = 0.15
  plasmoid_radius      = 0.4
  plasmoid_sep         = 1.2
  b_core               = 1.0
  b_guide              = 0.1
  v_inflow             = 0.1
  v_profile_radius     = 0.5
  v_bulk               = 0.24

  eta_hall             = 0.08
  hall_theta           = 0.5
  hall_tol             = 1e-8
  hall_max_iter        = 40
  hall_cfl             = 0.01
  hall_implicit        = 0
  hall_implicit_include_ohm = 0
  eta_ohm              = 0.0
</problem>

<hydro>
  gamma = 5.0/3.0
  reconstruction = plm
  riemann_solver = hlld
</hydro>

<field>
  integration = ct
</field>
