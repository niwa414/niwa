{
  "id": "m3-h3b-hybrid-merge-tilt-3d-gamma",
  "description": "Post-merge tilt growth-rate fit (gamma, R2) based on H3a output.",
  "engine": "analysis",
  "gate_class": "hybrid_gate",
  "physical_validity": "3d_hybrid_merge_tilt_gamma",
  "inputs": [
    "../../outputs/m3-h3a-hybrid-merge-tilt-3d/analysis/tilt_post_merge_series.csv",
    "../../outputs/m3-h3a-hybrid-merge-tilt-3d/analysis/metrics.json"
  ],
  "run": [
    {
      "name": "prepare-run-dir",
      "cmd": [
        "mkdir",
        "-p",
        "{output_raw}/run"
      ]
    }
  ],
  "analyze": [
    {
      "name": "analyze-h3b-gamma",
      "cmd": [
        "{python}",
        "tools/analyze_h3b_growth_fit.py",
        "--series",
        "outputs/m3-h3a-hybrid-merge-tilt-3d/analysis/tilt_post_merge_series.csv",
        "--source-metrics",
        "outputs/m3-h3a-hybrid-merge-tilt-3d/analysis/metrics.json",
        "--metrics",
        "{output_analysis}/metrics.json",
        "--plots-dir",
        "{output_plots}",
        "--fit-csv",
        "{output_analysis}/fit_series.csv",
        "--smooth-window",
        "7",
        "--smooth-mode",
        "mean",
        "--floor-percentile",
        "10",
        "--abs-eps",
        "1e-12",
        "--min-amp-ratio",
        "1.05",
        "--min-points",
        "30"
      ]
    }
  ],
  "metrics_file": "{output_analysis}/metrics.json",
  "thresholds": [
    {
      "metric": "fit_found",
      "op": "==",
      "value": true
    },
    {
      "metric": "fit_points",
      "op": ">=",
      "value": 30
    },
    {
      "metric": "gamma_best",
      "op": ">",
      "value": 0.0
    },
    {
      "metric": "r2_best",
      "op": ">=",
      "value": 0.8
    },
    {
      "metric": "amp_ratio_fit_best",
      "op": ">=",
      "value": 1.1
    },
    {
      "metric": "no_nan_in_metrics",
      "op": "==",
      "value": true
    }
  ],
  "artifacts": [
    "{output_analysis}/metrics.json",
    "{output_analysis}/fit_series.csv",
    "{output_plots}/tilt_amp_post_merge.png",
    "{output_plots}/tilt_log_fit.png"
  ]
}
