{
  "id": "m17-b2-p12-injectGateIstepSmoke",
  "description": "Inject istep gate smoke (inject_end_istep=16).",
  "case_notes": "inject_end_istep=16, max_steps=64, off_step=16; reset off.",
  "engine": "warpx",
  "gate_class": "runtime_guard_probe",
  "physical_validity": "runtime_guard_probe",
  "inputs": [
    "inputs/warpx_args.json",
    "inputs/h5_seed_config.json"
  ],
  "run": [
    {
      "name": "prepare-run-dir",
      "cmd": [
        "mkdir",
        "-p",
        "{output_raw}/run"
      ]
    },
    {
      "name": "run-warpx-3d-hybrid",
      "timeout_s": 43200,
      "cmd": [
        "env",
        "OMP_NUM_THREADS=4",
        "PYTHONPATH=pic-warpx-25.11/build-3d/lib/site-packages",
        "{python}",
        "warpx-driver/warpx_driver_3d.py",
        "--from-json",
        "{case_dir}/inputs/warpx_args.json",
        "--init-mode",
        "opmd_double_seed",
        "--opmd-fluid",
        "outputs/m9-h4-1-mhd-seeded-hybrid-3d-rotation/raw/run/fluid_init.h5",
        "--opmd-b",
        "outputs/m9-h4-1-mhd-seeded-hybrid-3d-rotation/raw/run/B_ext.h5",
        "--metadata-dir",
        "{output_raw}/run",
        "--diag-dir",
        "{output_raw}/run/diag",
        "--run-tag",
        "m17-b2-p12-injectGateIstepSmoke"
      ]
    }
  ],
  "analyze": [],
  "artifacts": [
    "{output_raw}/run/warpx_heartbeat.json",
    "{output_raw}/run/diag/reducedfiles/U2.txt",
    "{output_analysis}/metrics_runtime_guards.json"
  ],
  "metrics_file": "{output_analysis}/metrics_runtime_guards.json",
  "artifact_policy": {
    "archive_pass": false,
    "prune_raw_on_fail": false,
    "prune_raw_on_pass": false
  }
}