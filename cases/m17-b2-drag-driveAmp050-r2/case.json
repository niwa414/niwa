{
  "id": "m17-b2-drag-driveAmp050-r2",
  "description": "P6.5 drag + u2 stats driveAmp sweep (opmd_b_scale=0.5).",
  "case_notes": "U2 stats with energy drag: opmd_b_scale=0.5, interval=4, max_steps=513. (r2)",
  "engine": "warpx",
  "gate_class": "b2_drag_u2",
  "physical_validity": "b2_drag_u2",
  "inputs": [
    "inputs/warpx_args.json",
    "inputs/h5_seed_config.json"
  ],
  "run": [
    {
      "name": "prepare-run-dir",
      "cmd": [
        "mkdir",
        "-p",
        "{output_raw}/run"
      ]
    },
    {
      "name": "run-warpx-3d-hybrid",
      "timeout_s": 43200,
      "cmd": [
        "env",
        "OMP_NUM_THREADS=4",
        "PYTHONPATH=pic-warpx-25.11/build-3d/lib/site-packages",
        "{python}",
        "warpx-driver/warpx_driver_3d.py",
        "--from-json",
        "{case_dir}/inputs/warpx_args.json",
        "--init-mode",
        "opmd_double_seed",
        "--opmd-fluid",
        "outputs/m9-h4-1-mhd-seeded-hybrid-3d-rotation/raw/run/fluid_init.h5",
        "--opmd-b",
        "outputs/m9-h4-1-mhd-seeded-hybrid-3d-rotation/raw/run/B_ext.h5",
        "--metadata-dir",
        "{output_raw}/run",
        "--diag-dir",
        "{output_raw}/run/diag",
        "--run-tag",
        "m17-b2-drag-driveAmp050"
      ]
    }
  ],
  "analyze": [
    {
      "name": "analyze-u2-stats",
      "cmd": [
        "{python}",
        "tools/analyze_u2_stats.py",
        "--u2",
        "{output_raw}/run/diag/reducedfiles/U2.txt",
        "--metrics-out",
        "{output_analysis}/metrics_u2.json"
      ]
    }
  ],
  "artifacts": [
    "{output_raw}/run/warpx_heartbeat.json",
    "{output_raw}/run/diag/reducedfiles/U2.txt",
    "{output_analysis}/metrics_u2.json"
  ],
  "metrics_file": "{output_analysis}/metrics_u2.json",
  "artifact_policy": {
    "archive_pass": false,
    "prune_raw_on_fail": false,
    "prune_raw_on_pass": false
  },
  "thresholds": [
    {
      "metric": "u2_has_nan",
      "op": "==",
      "value": false
    },
    {
      "metric": "u2_series_len_unique",
      "op": ">=",
      "value": 129
    }
  ]
}