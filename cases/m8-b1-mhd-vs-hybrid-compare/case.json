{
  "id": "m8-b1-mhd-vs-hybrid-compare",
  "description": "B1 gate: MHD vs Hybrid comparison (t0 agreement + short-window drift).",
  "engine": "pipeline",
  "gate_class": "b1_compare",
  "physical_validity": "mhd_vs_hybrid_compare",
  "inputs": [
    "inputs/handoff_config.json",
    "inputs/warpx_args.json",
    "inputs/compare_config.json"
  ],
  "run": [
    {
      "name": "prepare-h4-handoff",
      "cmd": [
        "{python}",
        "tools/prepare_h4_handoff.py",
        "--config",
        "{case_dir}/inputs/handoff_config.json",
        "--output-dir",
        "{output_raw}/run"
      ]
    },
    {
      "name": "run-warpx-3d-hybrid",
      "timeout_s": 1800,
      "cmd": [
        "env",
        "OMP_NUM_THREADS=1",
        "PYTHONPATH=pic-warpx-25.11/build-3d/lib/site-packages",
        "{python}",
        "warpx-driver/warpx_driver_3d.py",
        "--from-json",
        "{case_dir}/inputs/warpx_args.json",
        "--init-mode",
        "opmd",
        "--opmd-fluid",
        "{output_raw}/run/fluid_init.h5",
        "--opmd-b",
        "{output_raw}/run/B_ext.h5",
        "--metadata-dir",
        "{output_raw}/run",
        "--diag-dir",
        "{output_raw}/run/diag",
        "--run-tag",
        "m8-b1-mhd-vs-hybrid-compare"
      ]
    }
  ],
  "analyze": [
    {
      "name": "analyze-h4-continuation",
      "cmd": [
        "{python}",
        "tools/analyze_h4_continuation_case.py",
        "--handoff-meta",
        "{output_raw}/run/handoff_meta.json",
        "--warpx-meta",
        "{output_raw}/run/warpx_run_m8-b1-mhd-vs-hybrid-compare.json",
        "--diag-dir",
        "{output_raw}/run/diag",
        "--metrics",
        "{output_analysis}/metrics_h4.json",
        "--summary",
        "{output_analysis}/mapping_summary.json",
        "--plots-dir",
        "{output_plots}"
      ]
    },
    {
      "name": "analyze-b1-compare",
      "cmd": [
        "{python}",
        "tools/analyze_b1_mhd_vs_hybrid_compare.py",
        "--metrics-in",
        "{output_analysis}/metrics_h4.json",
        "--summary-in",
        "{output_analysis}/mapping_summary.json",
        "--warpx-meta",
        "{output_raw}/run/warpx_run_m8-b1-mhd-vs-hybrid-compare.json",
        "--config",
        "{case_dir}/inputs/compare_config.json",
        "--metrics",
        "{output_analysis}/metrics.json",
        "--summary",
        "{output_analysis}/compare_summary.json"
      ]
    }
  ],
  "metrics_file": "{output_analysis}/metrics.json",
  "thresholds": [
    {
      "metric": "opmd_exists",
      "op": "==",
      "value": true
    },
    {
      "metric": "opmd_fields_present",
      "op": "==",
      "value": true
    },
    {
      "metric": "opmd_no_nan",
      "op": "==",
      "value": true
    },
    {
      "metric": "particle_load_ok",
      "op": "==",
      "value": true
    },
    {
      "metric": "warpx_ran_to_completion",
      "op": "==",
      "value": true
    },
    {
      "metric": "warpx_no_nan_in_metrics",
      "op": "==",
      "value": true
    },
    {
      "metric": "warpx_drop_breach",
      "op": "==",
      "value": false
    },
    {
      "metric": "energy_spectrum_records_count",
      "op": ">=",
      "value": 3
    },
    {
      "metric": "energy_spectrum_window_min_eV",
      "op": "<=",
      "value": 1000000000.0
    },
    {
      "metric": "energy_spectrum_window_max_eV",
      "op": ">=",
      "value": 1e+16
    },
    {
      "metric": "energy_spectrum_bins",
      "op": ">=",
      "value": 200
    },
    {
      "metric": "energy_spectrum_species",
      "op": "==",
      "value": "ions"
    }
  ],
  "artifacts": [
    "{output_raw}/run/handoff_meta.json",
    "{output_raw}/run/fluid_init.h5",
    "{output_raw}/run/B_ext.h5",
    "{output_raw}/run/warpx_run_m8-b1-mhd-vs-hybrid-compare.json",
    "{output_analysis}/metrics_h4.json",
    "{output_analysis}/metrics.json",
    "{output_analysis}/metrics_b1_energy.json",
    "{output_analysis}/mapping_summary.json",
    "{output_analysis}/compare_summary.json",
    "{output_plots}/rho_slice_mhd_vs_warpx_t0.png",
    "{output_plots}/B_slice_mhd_vs_warpx_t0.png",
    "{output_plots}/global_budget_vs_time.png",
    "{output_plots}/global_budget_vs_time_overlay_mhd_vs_warpx.png",
    "{output_plots}/traj_rel_error_vs_time.png",
    "{output_plots}/particle_energy_spectrum_compare.png",
    "{output_plots}/particle_weight_hist.png"
  ]
}
