{
  "analyze": [
    {
      "name": "analyze-formation-0d",
      "cmd": [
        "{python}",
        "tools/analyze_formation_0d.py",
        "--particle-number",
        "{output_raw}/run/diags/reducedfiles/PNUM.txt",
        "--rho-max",
        "{output_raw}/run/diags/reducedfiles/RHOMAX.txt",
        "--particle-energy",
        "{output_raw}/run/diags/reducedfiles/PENERGY.txt",
        "--field-energy",
        "{output_raw}/run/diags/reducedfiles/ENERGY0D.txt",
        "--metrics-out",
        "{output_analysis}/metrics_formation.json"
      ]
    }
  ],
  "artifact_policy": {
    "archive_pass": false,
    "prune_raw_on_fail": false,
    "prune_raw_on_pass": false
  },
  "artifacts": [
    "{output_raw}/run/warpx_heartbeat.json",
    "{output_raw}/run/diags/reducedfiles/PNUM.txt",
    "{output_raw}/run/diags/reducedfiles/RHOMAX.txt",
    "{output_raw}/run/diags/reducedfiles/PENERGY.txt",
    "{output_raw}/run/diags/reducedfiles/ENERGY0D.txt",
    "{output_analysis}/metrics_formation.json"
  ],
  "case_notes": "Formation0D ext_drive_start_step sweep: start=64, interval=4, max_steps=513; ParticleNumber/RhoMaximum/ParticleEnergy/FieldEnergy reduced diags.",
  "description": "P3.3 formation0d ext_drive_start_step sweep (64).",
  "engine": "warpx",
  "gate_class": "b2_formation0d_drive_start",
  "id": "m17-b2-formation0d-driveStart064",
  "inputs": [
    "inputs/warpx_args.json",
    "inputs/h5_seed_config.json"
  ],
  "metrics_file": "{output_analysis}/metrics_formation.json",
  "physical_validity": "b2_formation0d_drive_start",
  "run": [
    {
      "cmd": [
        "mkdir",
        "-p",
        "{output_raw}/run"
      ],
      "name": "prepare-run-dir"
    },
    {
      "cmd": [
        "env",
        "OMP_NUM_THREADS=4",
        "PYTHONPATH=pic-warpx-25.11/build-3d/lib/site-packages",
        "{python}",
        "warpx-driver/warpx_driver_3d.py",
        "--from-json",
        "{case_dir}/inputs/warpx_args.json",
        "--init-mode",
        "opmd_double_seed",
        "--opmd-fluid",
        "outputs/m9-h4-1-mhd-seeded-hybrid-3d-rotation/raw/run/fluid_init.h5",
        "--opmd-b",
        "outputs/m9-h4-1-mhd-seeded-hybrid-3d-rotation/raw/run/B_ext.h5",
        "--metadata-dir",
        "{output_raw}/run",
        "--diag-dir",
        "{output_raw}/run/diag",
        "--run-tag",
        "m17-b2-formation0d-driveStart064"
      ],
      "name": "run-warpx-3d-hybrid",
      "timeout_s": 43200
    }
  ],
  "thresholds": [
    {
      "metric": "formation_series_len",
      "op": ">=",
      "value": 129
    },
    {
      "metric": "formation_has_nan",
      "op": "==",
      "value": false
    }
  ]
}
