{
  "analyze": [
    {
      "cmd": [
        "{python}",
        "tools/analyze_h3a_merge_tilt_case.py",
        "--diag-dir",
        "{output_raw}/run/diag",
        "--metadata",
        "{output_raw}/run/warpx_run_m17-b2-tilt-m1inject-velkick-eps000-hires.json",
        "--metrics",
        "{output_analysis}/metrics_h3a.json",
        "--plots-dir",
        "{output_plots}",
        "--sep-csv",
        "{output_analysis}/separation_series.csv",
        "--tilt-csv",
        "{output_analysis}/tilt_post_merge_series.csv",
        "--tilt-metric",
        "slope",
        "--tilt-z-bins",
        "16",
        "--merge-frac",
        "0.6",
        "--merge-floor-mult",
        "1.7",
        "--guard-outputs",
        "2",
        "--sep-mode",
        "x",
        "--merge-method",
        "kmeans",
        "--kmeans-max-points",
        "50000",
        "--kmeans-iter",
        "10",
        "--kmeans-threshold-frac",
        "0.6",
        "--kmeans-bg-quantile",
        "10",
        "--kmeans-min-ratio",
        "0.2",
        "--kmeans-warm-start",
        "1",
        "--kmeans-coords",
        "x",
        "--kmeans-merge-criterion",
        "sep",
        "--kmeans-inertia-guard-outputs",
        "1",
        "--merge-persist",
        "3",
        "--diag-stride",
        "2"
      ],
      "name": "analyze-h5-merge-tilt"
    },
    {
      "cmd": [
        "{python}",
        "tools/analyze_h3b_growth_fit.py",
        "--series",
        "{output_analysis}/tilt_post_merge_series.csv",
        "--source-metrics",
        "{output_analysis}/metrics_h3a.json",
        "--metrics",
        "{output_analysis}/metrics_h3b.json",
        "--plots-dir",
        "{output_plots}",
        "--fit-csv",
        "{output_analysis}/tilt_fit_series.csv"
      ],
      "name": "analyze-h5-gamma-fit"
    },
    {
      "cmd": [
        "{python}",
        "tools/analyze_h5_merge_tilt_gamma.py",
        "--h3a-metrics",
        "{output_analysis}/metrics_h3a.json",
        "--h3b-metrics",
        "{output_analysis}/metrics_h3b.json",
        "--warpx-meta",
        "{output_raw}/run/warpx_run_m17-b2-tilt-m1inject-velkick-eps000-hires.json",
        "--metrics-out",
        "{output_analysis}/metrics.json"
      ],
      "name": "analyze-h5-merge-gamma"
    }
  ],
  "artifact_policy": {
    "archive_pass": false,
    "prune_raw_on_fail": false,
    "prune_raw_on_pass": false
  },
  "artifacts": [
    "{output_raw}/run/warpx_run_m17-b2-tilt-m1inject-velkick-eps000-hires.json",
    "{output_raw}/run/drift_meta.json",
    "{output_analysis}/metrics.json",
    "{output_analysis}/metrics_h3a.json",
    "{output_analysis}/metrics_h3b.json",
    "{output_analysis}/separation_series.csv",
    "{output_analysis}/tilt_post_merge_series.csv",
    "{output_analysis}/tilt_fit_series.csv",
    "{output_plots}/separation_vs_time.png",
    "{output_plots}/separation_kmeans_vs_time.png",
    "{output_plots}/kmeans_inertia_ratio_vs_time.png",
    "{output_plots}/merge_time_comparison.png",
    "{output_plots}/centroid_paths_two_blobs.png",
    "{output_plots}/tilt_centroid_amp_post_merge.png",
    "{output_plots}/tilt_slope_post_merge.png",
    "{output_plots}/tilt_amp_post_merge.png",
    "{output_plots}/tilt_log_fit.png",
    "{output_plots}/energy_budget_vs_time.png",
    "{output_plots}/density_snapshot.png"
  ],
  "case_notes": "P3.2 hires transient capture: vel_kick eps=0.00, diag_period=1, max_steps=64.",
  "description": "P3.2 m1 inject: vel_kick eps=0.00 (hires, 64-step).",
  "engine": "warpx",
  "gate_class": "b2_tilt_m1inject_velkick_eps000_hires",
  "id": "m17-b2-tilt-m1inject-velkick-eps000-hires",
  "inputs": [
    "inputs/warpx_args.json",
    "inputs/h5_seed_config.json"
  ],
  "metrics_file": "{output_analysis}/metrics.json",
  "physical_validity": "b2_tilt_m1inject_velkick_eps000_hires",
  "run": [
    {
      "cmd": [
        "mkdir",
        "-p",
        "{output_raw}/run"
      ],
      "name": "prepare-run-dir"
    },
    {
      "cmd": [
        "env",
        "OMP_NUM_THREADS=4",
        "PYTHONPATH=pic-warpx-25.11/build-3d/lib/site-packages",
        "{python}",
        "warpx-driver/warpx_driver_3d.py",
        "--from-json",
        "{case_dir}/inputs/warpx_args.json",
        "--init-mode",
        "opmd_double_seed",
        "--opmd-fluid",
        "outputs/m9-h4-1-mhd-seeded-hybrid-3d-rotation/raw/run/fluid_init.h5",
        "--opmd-b",
        "outputs/m9-h4-1-mhd-seeded-hybrid-3d-rotation/raw/run/B_ext.h5",
        "--metadata-dir",
        "{output_raw}/run",
        "--diag-dir",
        "{output_raw}/run/diag",
        "--run-tag",
        "m17-b2-tilt-m1inject-velkick-eps000-hires"
      ],
      "name": "run-warpx-3d-hybrid",
      "timeout_s": 43200
    }
  ],
  "thresholds": [
    {
      "metric": "ran_to_completion",
      "op": "==",
      "value": true
    },
    {
      "metric": "tilt_seed_enabled",
      "op": "==",
      "value": false
    },
    {
      "metric": "tilt_amp_series_len",
      "op": ">=",
      "value": 30
    },
    {
      "metric": "r2_fit_best",
      "op": ">=",
      "value": 0.9
    },
    {
      "metric": "merge_time_ok",
      "op": "==",
      "value": true
    },
    {
      "metric": "fit_window_found",
      "op": "==",
      "value": true
    },
    {
      "metric": "fit_points",
      "op": ">=",
      "value": 12
    },
    {
      "metric": "no_nan_in_metrics",
      "op": "==",
      "value": true
    }
  ],
  "thresholds_layers": [
    {
      "name": "layer1",
      "thresholds": [
        {
          "metric": "ran_to_completion",
          "op": "==",
          "value": true
        },
        {
          "metric": "tilt_seed_enabled",
          "op": "==",
          "value": false
        },
        {
          "metric": "tilt_amp_series_len",
          "op": ">=",
          "value": 30
        }
      ]
    },
    {
      "name": "layer2",
      "thresholds": [
        {
          "metric": "fit_points",
          "op": ">=",
          "value": 24
        },
        {
          "metric": "r2_fit_best",
          "op": ">=",
          "value": 0.9
        }
      ]
    },
    {
      "name": "layer3",
      "thresholds": [
        {
          "metric": "gamma_fit",
          "op": ">",
          "value": 0.0
        }
      ]
    }
  ]
}
