{
  "id": "m19-b2-3d-driver-stage1-gate60",
  "description": "B2 3D driver stage1 Gate60 suite (GS->3D + EMF + moving-wall; progress~0.60).",
  "engine": "pipeline",
  "gate_class": "b2_3d_driver_stage1",
  "physical_validity": "limited",
  "inputs": [
    "../../athena-24.0/inputs/mhd/athinput.belova_b2_gs_emf_mwall3d_gate60",
    "../../athena-24.0/inputs/mhd/athinput.belova_b2_gs_emf_mwall80_smooth",
    "../../scenes/belova_b2_mirror_ramp_smooth.csv"
  ],
  "run": [
    {
      "name": "prepare-run-dir",
      "cmd": [
        "mkdir",
        "-p",
        "{output_raw}/run"
      ]
    },
    {
      "name": "run-stage1-suite",
      "timeout_s": 7200,
      "cmd": [
        "{python}",
        "tools/run_b2_3d_driver_stage.py",
        "--stage",
        "3d1",
        "--output-root",
        "{output_raw}/run",
        "--athena-bin",
        "athena-24.0/bin/athena",
        "--stage-input",
        "athena-24.0/inputs/mhd/athinput.belova_b2_gs_emf_mwall3d_gate60",
        "--gs-athinput",
        "athena-24.0/inputs/mhd/athinput.belova_b2_gs_emf_mwall80_smooth",
        "--waveform",
        "scenes/belova_b2_mirror_ramp_smooth.csv"
      ]
    }
  ],
  "analyze": [
    {
      "name": "analyze-stage1-suite",
      "cmd": [
        "{python}",
        "tools/analyze_b2_3d_driver_stage.py",
        "--summary",
        "{output_raw}/run/stage_summary.json",
        "--metrics",
        "{output_analysis}/metrics.json",
        "--details",
        "{output_analysis}/stage1_details.json"
      ]
    }
  ],
  "metrics_file": "{output_analysis}/metrics.json",
  "thresholds": [
    {
      "metric": "init_h5_exists",
      "op": "==",
      "value": true
    },
    {
      "metric": "stage_pass",
      "op": "==",
      "value": true
    },
    {
      "metric": "stage_suite_pass",
      "op": "==",
      "value": true
    }
  ],
  "known_gaps": [
    "b2_3d_stage2_gate80_not_included"
  ],
  "artifacts": [
    "{output_raw}/run/stage_summary.json",
    "{output_analysis}/metrics.json",
    "{output_analysis}/stage1_details.json"
  ]
}
