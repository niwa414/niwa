{
  "analyze": [
    {
      "cmd": [
        "{python}",
        "tools/analyze_h5_merge_tilt_gamma.py",
        "--h3a-metrics",
        "{output_analysis}/metrics_h3a.json",
        "--h3b-metrics",
        "{output_analysis}/metrics_h3b.json",
        "--warpx-meta",
        "{output_raw}/run/warpx_run_m17-b2-p15-circuitSmoke-off032-driveAmp010.json",
        "--metrics-out",
        "{output_analysis}/metrics.json"
      ],
      "name": "analyze-h5-merge-gamma"
    }
  ],
  "artifact_policy": {
    "archive_pass": false,
    "prune_raw_on_fail": false,
    "prune_raw_on_pass": false
  },
  "artifacts": [
    "{output_raw}/run/warpx_heartbeat.json",
    "{output_raw}/run/diag/reducedfiles/COIL.txt",
    "{output_analysis}/metrics.json"
  ],
  "case_notes": "driveAmp_scale=0.1; off_step=32; inject disabled; max_steps=128.",
  "description": "P15.3b circuit smoke off_step=32 (driveAmp=0.1).",
  "engine": "warpx",
  "gate_class": "b2_p15_circuit_smoke",
  "id": "m17-b2-p15-circuitSmoke-off032-driveAmp010",
  "inputs": [
    "inputs/warpx_args.json",
    "inputs/h5_seed_config.json"
  ],
  "metrics_file": "{output_analysis}/metrics.json",
  "physical_validity": "b2_p15_circuit_smoke",
  "run": [
    {
      "cmd": [
        "mkdir",
        "-p",
        "{output_raw}/run"
      ],
      "name": "prepare-run-dir"
    },
    {
      "cmd": [
        "env",
        "OMP_NUM_THREADS=4",
        "PYTHONPATH=pic-warpx-25.11/build-3d/lib/site-packages",
        "{python}",
        "warpx-driver/warpx_driver_3d.py",
        "--from-json",
        "{case_dir}/inputs/warpx_args.json",
        "--init-mode",
        "opmd_double_seed",
        "--opmd-fluid",
        "outputs/m9-h4-1-mhd-seeded-hybrid-3d-rotation/raw/run/fluid_init.h5",
        "--opmd-b",
        "outputs/m9-h4-1-mhd-seeded-hybrid-3d-rotation/raw/run/B_ext.h5",
        "--metadata-dir",
        "{output_raw}/run",
        "--diag-dir",
        "{output_raw}/run/diag",
        "--run-tag",
        "m17-b2-p15-circuitSmoke-off032-driveAmp010"
      ],
      "name": "run-warpx-3d-hybrid",
      "timeout_s": 43200
    }
  ],
  "thresholds": [
    {
      "metric": "merge_time_ok",
      "op": "==",
      "value": true
    },
    {
      "metric": "fit_window_found",
      "op": "==",
      "value": true
    },
    {
      "metric": "fit_points",
      "op": ">=",
      "value": 12
    },
    {
      "metric": "no_nan_in_metrics",
      "op": "==",
      "value": true
    }
  ]
}
