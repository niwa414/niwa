{
  "id": "helion-live-tilt-tradestudy-knob-minus",
  "description": "Helion live trade study knob_minus (single knob: shift=-0.002).",
  "engine": "warpx",
  "gate_class": "helion_live_tilt_trade_study",
  "physical_validity": "single_knob_shift_live_trade_study",
  "case_notes": "Live WarpX run, only knob=opmd_double_seed_shift[0].",
  "metadata": {
    "trade_study": {
      "knob_name": "shift",
      "knob_value": -0.002,
      "role": "knob_minus"
    }
  },
  "inputs": [
    "inputs/warpx_args.json",
    "inputs/h5_seed_config.json"
  ],
  "artifact_policy": {
    "archive_pass": false,
    "prune_raw_on_pass": false,
    "prune_raw_on_fail": false
  },
  "run": [
    {
      "name": "prepare-run-dir",
      "cmd": [
        "mkdir",
        "-p",
        "{output_raw}/run"
      ]
    },
    {
      "name": "run-warpx-3d-hybrid",
      "timeout_s": 43200,
      "cmd": [
        "env",
        "OMP_NUM_THREADS=4",
        "PYTHONPATH=pic-warpx-25.11/build-3d/lib/site-packages",
        "{python}",
        "warpx-driver/warpx_driver_3d.py",
        "--from-json",
        "{case_dir}/inputs/warpx_args.json",
        "--init-mode",
        "opmd_double_seed",
        "--opmd-fluid",
        "outputs/m9-h4-1-mhd-seeded-hybrid-3d-rotation/raw/run/fluid_init.h5",
        "--opmd-b",
        "outputs/m9-h4-1-mhd-seeded-hybrid-3d-rotation/raw/run/B_ext.h5",
        "--metadata-dir",
        "{output_raw}/run",
        "--diag-dir",
        "{output_raw}/run/diag",
        "--run-tag",
        "helion-live-tilt-tradestudy-knob-minus"
      ]
    }
  ],
  "analyze": [
    {
      "name": "analyze-formation-0d",
      "cmd": [
        "{python}",
        "tools/analyze_formation_0d.py",
        "--particle-number",
        "{output_raw}/run/diags/reducedfiles/PNUM.txt",
        "--rho-max",
        "{output_raw}/run/diags/reducedfiles/RHOMAX.txt",
        "--particle-energy",
        "{output_raw}/run/diags/reducedfiles/PENERGY.txt",
        "--field-energy",
        "{output_raw}/run/diags/reducedfiles/ENERGY0D.txt",
        "--metrics-out",
        "{output_analysis}/metrics_formation.json"
      ]
    },
    {
      "name": "analyze-u2-hist",
      "cmd": [
        "{python}",
        "tools/analyze_u2_hist.py",
        "--hist",
        "{output_raw}/run/diag/reducedfiles/U2Hist.txt",
        "--warpx-args",
        "{case_dir}/inputs/warpx_args.json",
        "--metrics-out",
        "{output_analysis}/metrics_u2hist.json"
      ]
    },
    {
      "name": "analyze-h5-merge-gamma",
      "cmd": [
        "{python}",
        "tools/analyze_h5_merge_tilt_gamma.py",
        "--h3a-metrics",
        "{output_analysis}/metrics_h3a.json",
        "--h3b-metrics",
        "{output_analysis}/metrics_h3b.json",
        "--warpx-meta",
        "{output_raw}/run/warpx_run_helion-live-tilt-tradestudy-knob-minus.json",
        "--metrics-out",
        "{output_analysis}/metrics_source.json"
      ]
    },
    {
      "name": "analyze-helion-demo-case",
      "cmd": [
        "{python}",
        "tools/analyze_helion_demo_case.py",
        "--source-metrics",
        "{output_analysis}/metrics_source.json",
        "--source-formation",
        "{output_analysis}/metrics_formation.json",
        "--output-metrics",
        "{output_analysis}/metrics.json",
        "--source-case-id",
        "helion-live-tilt-tradestudy-knob-minus",
        "--knob-name",
        "shift",
        "--knob-value",
        "-0.002",
        "--label",
        "knob_minus",
        "--compression-threshold",
        "1.001",
        "--energy-threshold",
        "1e-6",
        "--tilt-threshold",
        "0.05"
      ]
    }
  ],
  "metrics_file": "{output_analysis}/metrics.json",
  "thresholds": [
    {
      "metric": "ran_to_completion",
      "op": "==",
      "value": true
    },
    {
      "metric": "no_nan_in_metrics",
      "op": "==",
      "value": true
    },
    {
      "metric": "merge_time_exists",
      "op": "==",
      "value": true
    },
    {
      "metric": "compression_ratio",
      "op": ">=",
      "value": 1.001
    },
    {
      "metric": "tilt_amp_max",
      "op": "<=",
      "value": 0.05
    },
    {
      "metric": "energy_accounting_ok",
      "op": "==",
      "value": true
    }
  ],
  "artifacts": [
    "{output_raw}/run/warpx_heartbeat.json",
    "{output_raw}/run/warpx_run_helion-live-tilt-tradestudy-knob-minus.json",
    "{output_raw}/run/diag/reducedfiles/COIL.txt",
    "{output_raw}/run/diag/reducedfiles/U2Hist.txt",
    "{output_raw}/run/diags/reducedfiles/ENERGY0D.txt",
    "{output_raw}/run/diags/reducedfiles/PNUM.txt",
    "{output_raw}/run/diags/reducedfiles/PENERGY.txt",
    "{output_raw}/run/diags/reducedfiles/RHOMAX.txt",
    "{output_analysis}/metrics_source.json",
    "{output_analysis}/metrics_formation.json",
    "{output_analysis}/metrics_u2hist.json",
    "{output_analysis}/metrics.json"
  ]
}
