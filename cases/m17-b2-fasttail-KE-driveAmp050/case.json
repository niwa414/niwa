{
  "id": "m17-b2-fasttail-KE-driveAmp050",
  "description": "P5-3 fasttail KE histogram driveAmp sweep (m17-b2-fasttail-KE-driveAmp050).",
  "case_notes": "Fasttail histogram sweep: opmd_b_scale=0.50, interval=4, max_steps=513; ParticleHistogram reduced diag only. (r2) (r3) (KE histogram)",
  "engine": "warpx",
  "gate_class": "b2_fasttail_drive_amp",
  "physical_validity": "b2_fasttail_drive_amp",
  "inputs": [
    "inputs/warpx_args.json",
    "inputs/h5_seed_config.json"
  ],
  "run": [
    {
      "name": "prepare-run-dir",
      "cmd": [
        "mkdir",
        "-p",
        "{output_raw}/run"
      ]
    },
    {
      "name": "run-warpx-3d-hybrid",
      "timeout_s": 43200,
      "cmd": [
        "env",
        "OMP_NUM_THREADS=4",
        "PYTHONPATH=pic-warpx-25.11/build-3d/lib/site-packages",
        "{python}",
        "warpx-driver/warpx_driver_3d.py",
        "--from-json",
        "{case_dir}/inputs/warpx_args.json",
        "--init-mode",
        "opmd_double_seed",
        "--opmd-fluid",
        "outputs/m9-h4-1-mhd-seeded-hybrid-3d-rotation/raw/run/fluid_init.h5",
        "--opmd-b",
        "outputs/m9-h4-1-mhd-seeded-hybrid-3d-rotation/raw/run/B_ext.h5",
        "--metadata-dir",
        "{output_raw}/run",
        "--diag-dir",
        "{output_raw}/run/diag",
        "--run-tag",
        "m17-b2-fasttail-KE-driveAmp050"
      ]
    }
  ],
  "analyze": [
    {
      "name": "analyze-fasttail-hist",
      "cmd": [
        "{python}",
        "tools/analyze_fasttail_hist.py",
        "--hist",
        "{output_raw}/run/diags/reducedfiles/EHist.txt",
        "--warpx-args",
        "{case_dir}/inputs/warpx_args.json",
        "--metrics-out",
        "{output_analysis}/metrics_fasttail.json",
        "--ethr-list",
        "0.02,0.05,0.08"
      ]
    }
  ],
  "artifacts": [
    "{output_raw}/run/warpx_heartbeat.json",
    "{output_raw}/run/diags/reducedfiles/EHist.txt",
    "{output_analysis}/metrics_fasttail.json"
  ],
  "metrics_file": "{output_analysis}/metrics_fasttail.json",
  "artifact_policy": {
    "archive_pass": false,
    "prune_raw_on_fail": false,
    "prune_raw_on_pass": false
  },
  "thresholds": [
    {
      "metric": "fasttail_hist_series_len",
      "op": ">=",
      "value": 129
    },
    {
      "metric": "fasttail_rows_used",
      "op": ">=",
      "value": 120
    },
    {
      "metric": "fasttail_has_nan",
      "op": "==",
      "value": false
    },
    {
      "metric": "fasttail_tail_frac_end",
      "op": ">=",
      "value": 0.0
    },
    {
      "metric": "fasttail_tail_frac_end",
      "op": "<=",
      "value": 1.0
    }
  ]
}