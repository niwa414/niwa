{
  "id": "m22-a4-eb-movingwall-stage2-tight",
  "description": "A4 Stage2 strict closure: EB/moving-wall geometric leak residual <= 1e-4 with baseline compare.",
  "engine": "athena",
  "gate_class": "a4_stage2_closure",
  "physical_validity": "a4_eb_movingwall_stage2",
  "inputs": [
    "inputs/athinput.a4_eb_movingwall_stage2_tight",
    "../../outputs/m15-a4-eb-movingwall-short/analysis/metrics.json",
    "../../outputs/m15-a4-eb-movingwall-short/raw/run/frc_merge.hst"
  ],
  "run": [
    {
      "name": "build-athena",
      "timeout_s": 600,
      "cmd": [
        "{python}",
        "tools/build_athena.py",
        "--athena-root",
        "athena-24.0",
        "--prob",
        "frc_merge",
        "--jobs",
        "4",
        "--magnetic",
        "--clean"
      ]
    },
    {
      "name": "prepare-run-dir",
      "cmd": [
        "mkdir",
        "-p",
        "{output_raw}/run"
      ]
    },
    {
      "name": "run-athena",
      "timeout_s": 900,
      "cmd": [
        "athena-24.0/bin/athena",
        "-i",
        "{case_dir}/inputs/athinput.a4_eb_movingwall_stage2_tight",
        "-d",
        "{output_raw}/run"
      ]
    }
  ],
  "analyze": [
    {
      "name": "analyze-a4-candidate",
      "cmd": [
        "{python}",
        "tools/analyze_a4_eb_wall_case.py",
        "--run-dir",
        "{output_raw}/run",
        "--athinput",
        "{case_dir}/inputs/athinput.a4_eb_movingwall_stage2_tight",
        "--metrics",
        "{output_analysis}/candidate_metrics.json",
        "--plots-dir",
        "{output_plots}/candidate"
      ]
    },
    {
      "name": "compare-a4-stage2",
      "cmd": [
        "{python}",
        "tools/analyze_a4_stage2_compare.py",
        "--candidate-metrics",
        "{output_analysis}/candidate_metrics.json",
        "--baseline-metrics",
        "outputs/m15-a4-eb-movingwall-short/analysis/metrics.json",
        "--candidate-hst",
        "{output_raw}/run/frc_merge.hst",
        "--baseline-hst",
        "outputs/m15-a4-eb-movingwall-short/raw/run/frc_merge.hst",
        "--metrics",
        "{output_analysis}/metrics.json",
        "--summary",
        "{output_analysis}/compare_summary.json",
        "--plot",
        "{output_plots}/leak_compare.png"
      ]
    }
  ],
  "metrics_file": "{output_analysis}/metrics.json",
  "thresholds": [
    {
      "metric": "ran_to_completion",
      "op": "==",
      "value": true
    },
    {
      "metric": "blocked_flux_faces_count",
      "op": ">",
      "value": 0
    },
    {
      "metric": "piston_metric",
      "op": ">",
      "value": 0.0
    },
    {
      "metric": "mass_budget_residual_geom_rel",
      "op": "<=",
      "value": 0.0001
    },
    {
      "metric": "leak_mass_frac_max_geom",
      "op": "<=",
      "value": 0.0001
    },
    {
      "metric": "control_curve_plot_exists",
      "op": "==",
      "value": true
    },
    {
      "metric": "residual_improve_factor",
      "op": ">",
      "value": 1.0
    }
  ],
  "artifacts": [
    "{output_raw}/run/frc_merge.hst",
    "{output_analysis}/candidate_metrics.json",
    "{output_analysis}/metrics.json",
    "{output_analysis}/compare_summary.json",
    "{output_plots}/candidate/leak_mass_out_vs_time.png",
    "{output_plots}/leak_compare.png"
  ]
}
